# Copy this file to .env and fill in real values. Never commit .env.
REACT_APP_BACKEND_URL=http://localhost:8001
ENABLE_HEALTH_CHECK=false

# Sentry - leave REACT_APP_SENTRY_DSN unset to disable entirely (local dev
# runs without it). REACT_APP_SENTRY_TRACES_SAMPLE_RATE defaults to 1.0 -
# dial this down once there's real production traffic.
REACT_APP_SENTRY_DSN=
REACT_APP_SENTRY_TRACES_SAMPLE_RATE=1.0
REACT_APP_ENVIRONMENT=development
