# Copy this file to .env and fill in real values. Never commit .env.
MONGO_URL=mongodb://localhost:27017
DB_NAME=test_database
CORS_ORIGINS=*

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Stripe
STRIPE_API_KEY=your_stripe_api_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8001/api/auth/google/callback

FRONTEND_URL=http://localhost:3000

# Duffel flights API
DUFFEL_API_KEY=your_duffel_api_key_here

# SerpApi (hotels)
SERPAPI_KEY=your_serpapi_key_here

# RapidAPI (Sky Scrapper)
RAPIDAPI_KEY=your_rapidapi_key_here

# Ignav flights API
IGNAV_API_KEY=your_ignav_api_key_here

# Admin usage-summary endpoint (GET /api/admin/usage-summary) - required
# header: X-Admin-Key. Leave unset to keep the endpoint disabled (403).
ADMIN_API_KEY=your_admin_api_key_here

# Sentry - leave SENTRY_DSN unset to disable entirely (local dev/tests run
# without it). SENTRY_TRACES_SAMPLE_RATE defaults to 1.0 (100% of requests
# traced) - dial this down once there's real production traffic.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
ENVIRONMENT=development

# Build/deploy identifier surfaced by GET /health and Sentry's release tag.
# Leave unset locally - falls back to `git rev-parse --short HEAD` read from
# the working tree. Set explicitly wherever the app is actually deployed
# (Docker build ARG, Railway/Vercel's own git-sha env var), since a built
# container image won't have .git to read from.
APP_VERSION=
